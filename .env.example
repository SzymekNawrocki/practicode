# Supabase — get these from your project's API settings (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Database — Supabase connection strings
# Transaction Pooler (port 6543) — used at runtime by the app
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (port 5432) — used by drizzle-kit for migrations only
DIRECT_DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.supabase.com:5432/postgres

# OpenRouter — get your key at openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# Your site URL (used for RSS feed and SEO metadata)
# In development, set to http://localhost:3000. In production, set to your real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Upstash Redis — rate limiting + daily token cap (free tier at upstash.com)
# Without these, the app starts but rate limiting silently fails (unsafe for production)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Sentry — error monitoring (free tier at sentry.io)
# Both vars must be set to the same DSN value
SENTRY_DSN=https://xxx@ooo.ingest.sentry.io/yyy
NEXT_PUBLIC_SENTRY_DSN=https://xxx@ooo.ingest.sentry.io/yyy
# Auth token for source map upload — set in Vercel, not in .env.local (keep secret)
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
